const $=id=>document.getElementById(id);
function rnd(n){return Array.from({length:n},()=>'abcdefghijklmnopqrstuvwxyz0123456789'[Math.floor(Math.random()*36)]).join('')}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function fmt(iso){
  if(!iso)return'';
  const d=new Date(iso),now=new Date(),df=now-d;
  if(df<60000)return T.timeJustNow;
  if(df<3600000)return Math.floor(df/60000)+T.timeMin;
  if(d.toDateString()===now.toDateString())return d.toLocaleTimeString(currentLang,{hour:'2-digit',minute:'2-digit'});
  return d.toLocaleDateString(currentLang,{day:'2-digit',month:'2-digit',year:'2-digit'});
}
