  setTimeout(()=>$('authEmail').focus(),120);
}
function closeAuthModal(){ $('authModalOv').classList.remove('open'); }
function closeAuthModalOv(e){ if(e.target===$('authModalOv'))closeAuthModal(); }

let authMode = 'login';
function switchAuthTab(mode){
  authMode = mode;
  $('authTabLogin').classList.toggle('active', mode==='login');
  $('authTabReg').classList.toggle('active', mode==='register');
  $('authSubmitBtn').textContent = mode==='login' ? 'Login' : 'Registrieren';
  $('authErr').classList.remove('show');
}

function setAuthErr(msg){ $('authErr').textContent=msg; $('authErr').classList.add('show'); }

function authSubmit(){
  const email = $('authEmail').value.trim();
  const pw = $('authPw').value;
  if(!email || !/@/.test(email)){ setAuthErr('Gültige E-Mail eingeben.'); return; }
  if(pw.length < 6){ setAuthErr('Passwort muss mindestens 6 Zeichen haben.'); return; }

  const users = JSON.parse(localStorage.getItem('altmail_users')||'{}');

  if(authMode === 'register'){
    if(users[email]){ setAuthErr('Account existiert bereits. Bitte einloggen.'); return; }
    const user = { email, pw: btoa(pw), name: email.split('@')[0], createdAt: new Date().toISOString() };
    users[email] = user;
    localStorage.setItem('altmail_users', JSON.stringify(users));
    currentUser = { email, name: user.name };
    saveUser(currentUser);
    updateAuthUI();
    closeAuthModal();
    showToast('✓ Account erstellt & eingeloggt');
  } else {
    const u = users[email];
    if(!u || atob(u.pw) !== pw){ setAuthErr('E-Mail oder Passwort falsch.'); return; }
    currentUser = { email, name: u.name };
    saveUser(currentUser);
    updateAuthUI();
    closeAuthModal();
    showToast('✓ Eingeloggt als ' + (u.name||email));
  }
}

function authLogout(){
  clearUser(); currentUser = null;
  updateAuthUI();
  closeAuthModal();
  showToast('Ausgeloggt');
}

function updateAuthUI(){
  const u = loadUser();
  const av = $('authAvatar');
  if(u){
    av.textContent = (u.email[0]||'?').toUpperCase();
    av.style.borderColor = 'rgba(255,255,255,0.3)';
    av.style.color = 'var(--txt)';
  } else {
    av.textContent = '?';
    av.style.borderColor = '';
    av.style.color = '';
  }
}

