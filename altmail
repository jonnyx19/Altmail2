}
function startTimer(){
  clearInterval(tIv);
  if(tMode==='unlimited'){$('timerReadout').textContent='∞';$('timerFill').style.width='100%';return;}
  tSecs=tMax;
  tIv=setInterval(()=>{
    tSecs--;
    const m=Math.floor(tSecs/60),s=tSecs%60;
    $('timerReadout').textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
    $('timerFill').style.width=(tSecs/tMax*100)+'%';
    if(tSecs<=0){clearInterval(tIv);doGenerate();}
  },1000);
}

// ── Generate ──────────────────────────────────────────────────────────
async function doGenerate(){
  clearInterval(aIv);clearInterval(tIv);
  tok='';addr='';pw='';msgs=[];
  $('emailAddr').textContent=T.generating;
  $('copyHint').textContent='';
  $('genBtn').disabled=true; $('saveBtn').disabled=true; $('refreshBtn').disabled=true;
  $('statusDot').className='status-dot loading';
  setStatus('loading', T.statusConnecting);
  renderInbox(true); closeDetail();

  try{
    const dr=await fetch(BASE+'/domains?page=1');
    if(!dr.ok)throw new Error('Domains: '+dr.status);
    const dd=await dr.json();
    const domain=(dd['hydra:member']||dd)[0]?.domain;
    if(!domain)throw new Error('No domain available');

    const user=rnd(10),password=rnd(14)+'Aa1!';
    const address=user+'@'+domain;
    const ar=await fetch(BASE+'/accounts',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address,password})});
    if(!ar.ok){const e=await ar.json().catch(()=>({}));throw new Error(e['hydra:description']||ar.status);}

    const tr=await fetch(BASE+'/token',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({address,password})});
    if(!tr.ok)throw new Error('Token: '+tr.status);
    tok=(await tr.json()).token; addr=address; pw=password;

    $('emailAddr').textContent=addr;
    $('copyHint').textContent=T.copyHint;
    $('statusDot').className='status-dot ok';
    $('genBtn').disabled=false; $('saveBtn').disabled=false; $('refreshBtn').disabled=false;
    setStatus('ok', T.statusReady);
    startTimer();
    await doFetch(false);
    aIv=setInterval(()=>doFetch(false),15000);
  }catch(e){
    console.error(e);
    $('statusDot').className='status-dot err';
    $('genBtn').disabled=false;
    $('emailAddr').textContent=T.errorRetry;
    setStatus('err', T.errNoEmail + e.message);
    renderInbox(false);
  }
}

// ── Fetch ─────────────────────────────────────────────────────────────
async function doFetch(manual=false){
  if(!tok)return;
  if(manual){$('refreshIco').className='spin';$('refreshBtn').disabled=true;}
  try{
    const r=await fetch(BASE+'/messages?page=1',{headers:{'Authorization':'Bearer '+tok}});
    if(r.status===401){setStatus('err', T.statusExpired);return;}
    if(!r.ok)throw new Error('HTTP '+r.status);
    const d=await r.json();
    const list=d['hydra:member']||[];
    const old=new Set(msgs.map(m=>m.id));
    const fresh=list.filter(m=>!old.has(m.id));
    if(fresh.length>0&&msgs.length>0){
      const pl=fresh.length>1?'s':'';
      showToast(T.toastNewMsg.replace('{n}',fresh.length).replace('{pl}',pl));
    }
    msgs=list;
    $('inboxCount').textContent=msgs.length;
    renderInbox(false);
    setStatus('ok', T.statusLastUpdate+new Date().toLocaleTimeString(currentLang,{hour:'2-digit',minute:'2-digit',second:'2-digit'}));
  }catch(e){setStatus('err', T.statusFailed);}
  finally{$('refreshIco').className='';$('refreshIco').textContent='↻';$('refreshBtn').disabled=false;}
}

