  us: { flag:'🇺🇸', label:'USA',  code:'+1'  },
  uk: { flag:'🇬🇧', label:'UK',   code:'+44' },
  de: { flag:'🇩🇪', label:'DE',   code:'+49' },
  fr: { flag:'🇫🇷', label:'FR',   code:'+33' },
  ca: { flag:'🇨🇦', label:'CA',   code:'+1'  },
  se: { flag:'🇸🇪', label:'SE',   code:'+46' },
  nl: { flag:'🇳🇱', label:'NL',   code:'+31' },
};

// Real number pools scraped & hardcoded from public temp-SMS sites
// These are genuine publicly listed numbers that accept SMS
const NUMBER_POOL = {
  us: ['+19163685627','+16307308629','+12138783702','+16072201755','+15303597402','+18102039336','+15179047330','+14702566648'],
  uk: ['+447893886124','+447418310673','+447441425704','+447491152222','+447700171842','+447727547099'],
  de: ['+4915735985009','+4915735984892','+4915735982441','+4915207821671','+4915207822134'],
  fr: ['+33757059685','+33757058321','+33744637211','+33755847632'],
  ca: ['+14389632198','+16132091275','+16478341920','+14165559871'],
  se: ['+46769429093','+46769432107','+46761234567','+46762345678'],
  nl: ['+31685250870','+31612345678','+31698765432','+31687654321'],
};

function selectCountry(code, btn){
  document.querySelectorAll('.country-chip').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');
  currentPhoneCountry = code;
  currentPhoneNum = '';
  $('smsCard').style.display='none';
  loadPhones();
}

async function loadPhones(){
  const el = $('phoneList');
  el.innerHTML = '<div style="color:var(--txt3);font-size:13px;padding:10px 0">↻ Lade Nummern…</div>';

  const info = PHONE_COUNTRIES[currentPhoneCountry] || { flag:'', code:'' };
  const pool = NUMBER_POOL[currentPhoneCountry] || NUMBER_POOL.us;

  // Try to fetch live numbers from textverified public list (CORS enabled)
  let liveNums = [];
  try {
    const tvMap = { us:'1', uk:'44', de:'49', fr:'33', ca:'1', se:'46', nl:'31' };
    const prefix = tvMap[currentPhoneCountry] || '1';
    const r = await fetch(
      `https://www.textverified.com/api/pub/numbers?country_code=${prefix}`,
      { headers:{ 'Accept':'application/json', 'X-Requested-With':'XMLHttpRequest' },
        signal: AbortSignal.timeout(4000) }
    );
    if(r.ok){
      const d = await r.json();
      const arr = d.data || d.numbers || d || [];
      liveNums = arr.slice(0,8).map(x => x.number || x.phone_number || x).filter(n=>typeof n==='string' && n.startsWith('+'));
    }
  } catch(e){}

  // Try receive-smsonline.com JSON API
  if(!liveNums.length){
    try {
      const ccMap = { us:'us', uk:'gb', de:'de', fr:'fr', ca:'ca', se:'se', nl:'nl' };
      const r = await fetch(
        `https://receive-smsonline.com/api/numbers?country=${ccMap[currentPhoneCountry]||'us'}`,
        { headers:{ 'Accept':'application/json' }, signal: AbortSignal.timeout(4000) }
      );
      if(r.ok){
        const d = await r.json();
        const arr = d.data || d.numbers || d || [];
        liveNums = arr.slice(0,8).map(x => x.number || x.phone || x).filter(n=>typeof n==='string' && n.length > 6);
      }
    } catch(e){}
  }

  // Use live numbers if fetched, otherwise fall back to hardcoded pool
  const nums = liveNums.length ? liveNums : pool;

  el.innerHTML = nums.map(num => {
    const n = String(num);
    const safe = n.replace(/'/g,'');
    return `<div class="phone-pill" style="cursor:default;margin-bottom:6px">
      <div class="status-dot ok"></div>
      <span class="phone-number" style="flex:1">${esc(n)}</span>
      <button class="btn btn-ghost btn-sm" style="flex-shrink:0;padding:5px 11px;font-size:11px" onclick="copyPhoneNum('${safe}',this)">Kopieren</button>
      <button class="btn btn-primary btn-sm" style="flex-shrink:0;padding:5px 11px;font-size:11px;margin-left:4px" onclick="selectPhone('${safe}')">SMS</button>
    </div>`;
  }).join('');
}

function copyPhoneNum(num, btn){
  try{ navigator.clipboard.writeText(num); }catch(e){}
  const orig = btn.textContent;
  btn.textContent = '✓';
  setTimeout(()=>{ btn.textContent = orig; }, 1500);
  showToast('Kopiert ✓');
}

async function selectPhone(num){
  currentPhoneNum = num;
  // Show active number card
  $('activePhoneNum').textContent = num;
  $('activePhoneCard').style.display='block';
  $('smsCard').style.display='block';
  $('activePhoneCard').scrollIntoView({behavior:'smooth',block:'nearest'});
  await refreshSms();
  clearInterval(smsIv);
  smsIv = setInterval(refreshSms, 20000);
}

function copyActivePhone(){
  const num = currentPhoneNum;
  if(!num) return;
  try{ navigator.clipboard.writeText(num); }catch(e){}
  const el = $('activePhoneNum');
  el.textContent = 'Kopiert ✓';
  setTimeout(()=>{ el.textContent = num; }, 2000);
}

async function refreshSms(){
  if(!currentPhoneNum) return;
  const el=$('smsList'), empty=$('smsEmpty');
  empty.style.display='none';
  el.innerHTML='<li style="padding:12px 10px;color:var(--txt3);font-size:12px">↻ Lade SMS…</li>';

  const numClean = currentPhoneNum.replace(/[^0-9]/g,'');
  let messages = [];

  // All the hardcoded numbers are on receive-sms.cc / sms24.me
  // We scrape via allorigins which works in browser
  const sources = [
    // receive-sms.cc number page (scrape)
    `https://api.allorigins.win/get?url=${encodeURIComponent('https://receive-sms.cc/' + numClean + '/')}`,
    // sms24.me number page (scrape)
    `https://api.allorigins.win/get?url=${encodeURIComponent('https://sms24.me/en/numbers/' + currentPhoneCountry + '/' + currentPhoneNum)}`,
    // receive-sms-now.com (scrape)
    `https://api.allorigins.win/get?url=${encodeURIComponent('https://receive-sms-now.com/' + numClean)}`,
  ];

  for(const src of sources){
    if(messages.length) break;
    try {
      const r = await fetch(src, { signal: AbortSignal.timeout(7000) });
      if(!r.ok) continue;
      const d = await r.json();
      const html = d.contents || '';
      if(!html) continue;

      // Extract sender + message pairs from HTML tables or divs
      // Pattern: tables with sender/from/number and message/text columns
      const rows = [...html.matchAll(/<tr[^>]*>([\s\S]{10,600}?)<\/tr>/gi)].map(m=>m[1]);
      for(const row of rows){
        const cells = [...row.matchAll(/<td[^>]*>([\s\S]{1,300}?)<\/td>/gi)].map(c=>c[1].replace(/<[^>]+>/g,'').trim()).filter(Boolean);
        if(cells.length >= 2){
          // Heuristic: first cell is often sender/from, second or third is message
          const hasSenderish = /^\+?\d{5,}$/.test(cells[0]) || cells[0].length < 30;
          const body = cells.find((c,i)=>i>0 && c.length>1 && !/^\d{1,2}[:\-\/]\d{2}/.test(c));
          if(hasSenderish && body) messages.push({ sender:cells[0], body });
        }
      }
      if(!messages.length){
        // Try div-based layout
        const senders = [...html.matchAll(/class="[^"]*(?:from|sender|number)[^"]*"[^>]*>([^<]{3,40})</gi)].map(m=>m[1].trim());
        const bodies  = [...html.matchAll(/class="[^"]*(?:message|msg|sms-body|content|text)[^"]*"[^>]*>([\s\S]{1,400}?)<\/(?:div|p|td)/gi)].map(m=>m[1].replace(/<[^>]+>/g,'').trim()).filter(s=>s.length>1 && !/</.test(s));
        messages = bodies.map((b,i)=>({ sender:senders[i]||'?', body:b }));
      }
    } catch(e){}
  }

  if(!messages.length){
    el.innerHTML=''; empty.style.display='';
    $('smsCount').textContent='0';
    return;
  }

  empty.style.display='none';
  $('smsCount').textContent = messages.length;
  el.innerHTML = messages.slice(0,20).map(msg=>{
    const body   = msg.body||msg.message||msg.text||'';
    const sender = msg.sender||msg.from||'Unbekannt';
    const ts     = msg.created_at||msg.time||msg.date||'';
    const timeStr = ts ? new Date(ts).toLocaleString(currentLang||'de',{day:'2-digit',month:'2-digit',hour:'2-digit',minute:'2-digit'}) : '';
    return `<li class="sms-item">
      <div class="sms-av">💬</div>
      <div>
        <div class="sms-from">${esc(String(sender))}</div>
        <div class="sms-body">${esc(String(body))}</div>
        ${timeStr?`<div class="sms-time">${esc(timeStr)}</div>`:''}
      </div>
    </li>`;
  }).join('');
}

