  DE:'de', AT:'de', CH:'de', LI:'de',
  US:'en', GB:'en', AU:'en', CA:'en', NZ:'en', IE:'en', ZA:'en', SG:'en', IN:'en', NG:'en', KE:'en', GH:'en',
  FR:'fr', BE:'fr', LU:'fr', MC:'fr', SN:'fr', CI:'fr', CM:'fr',
  ES:'es', MX:'es', AR:'es', CO:'es', CL:'es', PE:'es', VE:'es', EC:'es', GT:'es', CU:'es', BO:'es', DO:'es', HN:'es', PY:'es', SV:'es', NI:'es', CR:'es', PA:'es', UY:'es',
  BR:'pt', PT:'pt', AO:'pt', MZ:'pt',
  IT:'it', SM:'it', VA:'it',
  NL:'nl',
  PL:'pl',
  RU:'ru', BY:'ru', KZ:'ru',
  JP:'ja',
  CN:'zh', TW:'zh', HK:'zh', MO:'zh',
  TR:'tr',
};

let T = TRANSLATIONS.de; // default
let currentLang = 'de';

async function detectLanguage() {
  try {
    // Try browser language first as a quick heuristic
    const bLang = (navigator.language || 'de').split('-')[0].toLowerCase();

    // Fetch geo-IP
    const r = await fetch('https://ipapi.co/json/', { signal: AbortSignal.timeout(4000) });
    if (r.ok) {
      const d = await r.json();
      const countryCode = (d.country_code || '').toUpperCase();
      const langCode = COUNTRY_LANG[countryCode];
      if (langCode && TRANSLATIONS[langCode]) {
        applyLanguage(langCode);
        return;
      }
    }
  } catch(e) { /* fallback */ }

  // Fallback: browser language
  try {
    const bLang = (navigator.language || navigator.languages?.[0] || 'de').split('-')[0].toLowerCase();
    if (TRANSLATIONS[bLang]) { applyLanguage(bLang); return; }
  } catch(e) {}

  applyLanguage('en'); // final fallback
}

function applyLanguage(lang) {
  if (!TRANSLATIONS[lang]) lang = 'en';
  T = TRANSLATIONS[lang];
  currentLang = lang;
  document.documentElement.lang = lang;

  // Apply static UI strings
  $('headerChip').textContent = T.headerChip;
  $('heroTitle').childNodes[0].textContent = T.heroTitle + '\n';
  $('heroStrong').textContent = T.heroStrong;
  $('heroSub').textContent = T.heroSub;
