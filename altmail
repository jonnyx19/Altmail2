// ── Open message ──────────────────────────────────────────────────────
function extractLinks(text,html){
  const s=new Set();
  const re=/https?:\/\/[^\s"'<>)\]\\,]+/g;
  (text||'').match(re)?.forEach(u=>s.add(u.replace(/[.,;!?)>]+$/,'')));
  (html||'').match(re)?.forEach(u=>s.add(u.replace(/[.,;!?)>]+$/,'')));
  return[...s].filter(u=>!/(\.png|\.gif|\.jpg|\.jpeg|\.svg|\.ico|\.css|\.woff|unsubscribe)/i.test(u));
}
function isConfirm(u){return/confirm|verif|activat|token|auth|validate|magic|click|email.*link/i.test(u);}

async function openMsg(id){
  if(!tok)return;
  try{
    const r=await fetch(BASE+'/messages/'+id,{headers:{'Authorization':'Bearer '+tok}});
    if(!r.ok)throw new Error('HTTP '+r.status);
    const m=await r.json();
    $('dFrom').textContent=m.from?.address||T.unknown;
    $('dSubj').textContent=m.subject||T.noSubject;
    $('dMeta').textContent=T.to+(m.to?.[0]?.address||addr)+'  ·  '+new Date(m.createdAt).toLocaleString(currentLang);

    const htmlStr=Array.isArray(m.html)?m.html.join(''):(m.html||'');
    const all=extractLinks(m.text||'',htmlStr);
    const confirms=all.filter(isConfirm);
    const others=all.filter(u=>!isConfirm(u));

    let html='';
    if(confirms.length){
      html+=`<div style="margin-bottom:16px">
        <div class="links-label">${esc(T.linksConfirmLabel)}</div>
        ${confirms.map(u=>`<a class="link-card confirm" href="${esc(u)}" target="_blank" rel="noopener">
          <span class="link-confirm-badge">${esc(T.linkConfirmBadge)}</span>
          <span class="link-url">${esc(u)}</span>
          <span class="link-arrow">↗</span>
        </a>`).join('')}
      </div>`;
    }
    if(others.length){
      html+=`<div style="margin-bottom:16px">
        <div class="links-label">${esc(T.linksLabel)}</div>
        ${others.map(u=>`<a class="link-card" href="${esc(u)}" target="_blank" rel="noopener">
          <span class="link-url">${esc(u)}</span>
          <span class="link-arrow">↗</span>
        </a>`).join('')}
      </div>`;
    }
    if(m.text?.trim()){
      if(html)html+='<hr class="body-divider">';
      html+=`<div class="links-label" style="margin-bottom:10px">${esc(T.contentLabel)}</div><div class="email-body-text">${esc(m.text.trim())}</div>`;
    }
    if(!html)html=`<p style="color:var(--txt3);font-size:13px">${esc(T.emptyBody)}</p>`;
    $('dBody').innerHTML=html;
    $('detailCard').style.display='block';
    $('detailCard').scrollIntoView({behavior:'smooth',block:'nearest'});
  }catch(e){showToast(T.errNoEmail+e.message);}
}
