const AUTH_SK = 'altmail_auth';
let currentUser = null;

function loadUser(){ try{ return JSON.parse(localStorage.getItem(AUTH_SK)||'null'); }catch(e){ return null; } }
function saveUser(u){ localStorage.setItem(AUTH_SK, JSON.stringify(u)); }
function clearUser(){ localStorage.removeItem(AUTH_SK); }

function openAuthModal(){
